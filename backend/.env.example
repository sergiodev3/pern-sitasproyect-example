# Copia este archivo como .env y ajusta los valores:  cp .env.example .env

# Puerto donde corre la API
PORT=3000

# Cadena de conexión a PostgreSQL (formato: postgresql://usuario:password@host:puerto/base)
# Estos valores coinciden con el docker-compose.yml de la raíz del proyecto
# (el contenedor se expone en el puerto 5433 para no chocar con un
# PostgreSQL nativo que ya ocupe el 5432).
DATABASE_URL=postgresql://reservas_user:reservas_pass@localhost:5433/reservas_db

# Secreto para firmar los JWT. En producción usa una cadena larga y aleatoria,
# por ejemplo generada con:  node -e "console.log(crypto.randomBytes(32).toString('hex'))"
JWT_SECRET=cambia-esto-por-una-cadena-larga-y-aleatoria

# Origen permitido por CORS (la URL donde corre el frontend)
FRONTEND_URL=http://localhost:5173

# development | production
NODE_ENV=development

# --- Solo usadas por db/seed-admin.js (npm run db:seed-admin) ---
# No son necesarias para el arranque normal de la app (no están validadas
# en src/config/env.js). Sirven para crear/promover al primer usuario admin.
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=cambia-esto-tambien
